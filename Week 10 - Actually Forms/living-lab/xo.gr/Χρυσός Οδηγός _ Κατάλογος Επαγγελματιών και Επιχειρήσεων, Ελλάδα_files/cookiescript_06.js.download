 \\u03b9\\u03c3\\u03c4\\u03cc\\u03c4\\u03bf\\u03c0\\u03bf\\u03c2 \\u03c7\\u03c1\\u03b7\\u03c3\\u03b9\\u03bc\\u03bf\\u03c0\\u03bf\\u03b9\\u03b5\\u03af cookies \\u03b3\\u03b9\\u03b1 \\u03c4\\u03b7 \\u03b2\\u03b5\\u03bb\\u03c4\\u03af\\u03c9\\u03c3\\u03b7 \\u03c4\\u03b7\\u03c2 \\u03b5\\u03bc\\u03c0\\u03b5\\u03b9\\u03c1\\u03af\\u03b1\\u03c2 \\u03c4\\u03c9\\u03bd \\u03c7\\u03c1\\u03b7\\u03c3\\u03c4\\u03ce\\u03bd. \\u03a7\\u03c1\\u03b7\\u03c3\\u03b9\\u03bc\\u03bf\\u03c0\\u03bf\\u03b9\\u03ce\\u03bd\\u03c4\\u03b1\\u03c2 \\u03c4\\u03bf\\u03bd \\u03b9\\u03c3\\u03c4\\u03cc\\u03c4\\u03bf\\u03c0\\u03cc \\u03bc\\u03b1\\u03c2, \\u03c0\\u03b1\\u03c1\\u03ad\\u03c7\\u03b5\\u03c4\\u03b5 \\u03c4\\u03b7 \\u03c3\\u03c5\\u03b3\\u03ba\\u03b1\\u03c4\\u03ac\\u03b8\\u03b5\\u03c3\\u03ae \\u03c3\\u03b1\\u03c2 \\u03b3\\u03b9\\u03b1 \\u03cc\\u03bb\\u03b1 \\u03c4\\u03b1 cookies \\u03c3\\u03cd\\u03bc\\u03c6\\u03c9\\u03bd\\u03b1 \\u03bc\\u03b5 \\u03c4\\u03b7\\u03bd \\u03a0\\u03bf\\u03bb\\u03b9\\u03c4\\u03b9\\u03ba\\u03ae \\u03bc\\u03b1\\u03c2 \\u03b3\\u03b9\\u03b1 \\u03c4\\u03b1 cookies.&quot;}" data-cs-i18n-read="\u0391\u03c5\u03c4\u03cc\u03c2 \u03bf \u03b9\u03c3\u03c4\u03cc\u03c4\u03bf\u03c0\u03bf\u03c2 \u03c7\u03c1\u03b7\u03c3\u03b9\u03bc\u03bf\u03c0\u03bf\u03b9\u03b5\u03af cookies \u03b3\u03b9\u03b1 \u03c4\u03b7 \u03b2\u03b5\u03bb\u03c4\u03af\u03c9\u03c3\u03b7 \u03c4\u03b7\u03c2 \u03b5\u03bc\u03c0\u03b5\u03b9\u03c1\u03af\u03b1\u03c2 \u03c4\u03c9\u03bd \u03c7\u03c1\u03b7\u03c3\u03c4\u03ce\u03bd. \u03a7\u03c1\u03b7\u03c3\u03b9\u03bc\u03bf\u03c0\u03bf\u03b9\u03ce\u03bd\u03c4\u03b1\u03c2 \u03c4\u03bf\u03bd \u03b9\u03c3\u03c4\u03cc\u03c4\u03bf\u03c0\u03cc \u03bc\u03b1\u03c2, \u03c0\u03b1\u03c1\u03ad\u03c7\u03b5\u03c4\u03b5 \u03c4\u03b7 \u03c3\u03c5\u03b3\u03ba\u03b1\u03c4\u03ac\u03b8\u03b5\u03c3\u03ae \u03c3\u03b1\u03c2 \u03b3\u03b9\u03b1 \u03cc\u03bb\u03b1 \u03c4\u03b1 cookies \u03c3\u03cd\u03bc\u03c6\u03c9\u03bd\u03b1 \u03bc\u03b5 \u03c4\u03b7\u03bd \u03a0\u03bf\u03bb\u03b9\u03c4\u03b9\u03ba\u03ae \u03bc\u03b1\u03c2 \u03b3\u03b9\u03b1 \u03c4\u03b1 cookies.">\n      \u0391\u03c5\u03c4\u03cc\u03c2 \u03bf \u03b9\u03c3\u03c4\u03cc\u03c4\u03bf\u03c0\u03bf\u03c2 \u03c7\u03c1\u03b7\u03c3\u03b9\u03bc\u03bf\u03c0\u03bf\u03b9\u03b5\u03af cookies \u03b3\u03b9\u03b1 \u03c4\u03b7 \u03b2\u03b5\u03bb\u03c4\u03af\u03c9\u03c3\u03b7 \u03c4\u03b7\u03c2 \u03b5\u03bc\u03c0\u03b5\u03b9\u03c1\u03af\u03b1\u03c2 \u03c4\u03c9\u03bd \u03c7\u03c1\u03b7\u03c3\u03c4\u03ce\u03bd. \u03a7\u03c1\u03b7\u03c3\u03b9\u03bc\u03bf\u03c0\u03bf\u03b9\u03ce\u03bd\u03c4\u03b1\u03c2 \u03c4\u03bf\u03bd \u03b9\u03c3\u03c4\u03cc\u03c4\u03bf\u03c0\u03cc \u03bc\u03b1\u03c2, \u03c0\u03b1\u03c1\u03ad\u03c7\u03b5\u03c4\u03b5 \u03c4\u03b7 \u03c3\u03c5\u03b3\u03ba\u03b1\u03c4\u03ac\u03b8\u03b5\u03c3\u03ae \u03c3\u03b1\u03c2 \u03b3\u03b9\u03b1 \u03cc\u03bb\u03b1 \u03c4\u03b1 cookies \u03c3\u03cd\u03bc\u03c6\u03c9\u03bd\u03b1 \u03bc\u03b5 \u03c4\u03b7\u03bd \u03a0\u03bf\u03bb\u03b9\u03c4\u03b9\u03ba\u03ae \u03bc\u03b1\u03c2 \u03b3\u03b9\u03b1 \u03c4\u03b1 cookies.    <\/span>\n\n    \n      \n      <a\n        id="cookiescript_readmore"\n        data-cs-i18n-text="{&quot;el&quot;:&quot;\\u0394\\u03b9\\u03b1\\u03b2\\u03ac\\u03c3\\u03c4\\u03b5 \\u03c0\\u03b5\\u03c1\\u03b9\\u03c3\\u03c3\\u03cc\\u03c4\\u03b5\\u03c1\\u03b1&quot;,&quot;en&quot;:&quot;Read more&quot;}"\n        data-cs-i18n-url="{&quot;el&quot;:&quot;https:\\\/\\\/www.xo.gr\\\/oroi-chrisis-kai-politiki-prostasias-dedomenon\\\/&quot;,&quot;en&quot;:&quot;https:\\\/\\\/www.xo.gr\\\/terms-of-use-and-privacy-policy\\\/&quot;}"\n        target=\'_blank\'        aria-label="\u0394\u03b9\u03b1\u03b2\u03ac\u03c3\u03c4\u03b5 \u03c0\u03b5\u03c1\u03b9\u03c3\u03c3\u03cc\u03c4\u03b5\u03c1\u03b1, opens a new window"\n        href=\'https:\/\/www.xo.gr\/oroi-chrisis-kai-politiki-prostasias-dedomenon\/\'      >\n        \u0394\u03b9\u03b1\u03b2\u03ac\u03c3\u03c4\u03b5 \u03c0\u03b5\u03c1\u03b9\u03c3\u03c3\u03cc\u03c4\u03b5\u03c1\u03b1      <\/a>\n\n          <\/div>\n  <di