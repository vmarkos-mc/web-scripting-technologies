3c3\\u03c4\\u03bf\\u03cd \\u03c0\\u03bf\\u03c5 \\u03ad\\u03c7\\u03bf\\u03c5\\u03bd \\u03ba\\u03b1\\u03c4\\u03b1\\u03c3\\u03ba\\u03b5\\u03c5\\u03b1\\u03c3\\u03c4\\u03b5\\u03af \\u03c7\\u03c1\\u03b7\\u03c3\\u03b9\\u03bc\\u03bf\\u03c0\\u03bf\\u03b9\\u03ce\\u03bd\\u03c4\\u03b1\\u03c2 \\u03c4\\u03b5\\u03c7\\u03bd\\u03bf\\u03bb\\u03bf\\u03b3\\u03af\\u03b5\\u03c2 ASP.NET MVC. \\u0388\\u03c7\\u03b5\\u03b9 \\u03c3\\u03c7\\u03b5\\u03b4\\u03b9\\u03b1\\u03c3\\u03c4\\u03b5\\u03af \\u03b3\\u03b9\\u03b1 \\u03bd\\u03b1 \\u03c3\\u03c4\\u03b1\\u03bc\\u03b1\\u03c4\\u03ae\\u03c3\\u03b5\\u03b9 \\u03c4\\u03b7 \\u03bc\\u03b7 \\u03b5\\u03be\\u03bf\\u03c5\\u03c3\\u03b9\\u03bf\\u03b4\\u03bf\\u03c4\\u03b7\\u03bc\\u03ad\\u03bd\\u03b7 \\u03b4\\u03b7\\u03bc\\u03bf\\u03c3\\u03af\\u03b5\\u03c5\\u03c3\\u03b7 \\u03c0\\u03b5\\u03c1\\u03b9\\u03b5\\u03c7\\u03bf\\u03bc\\u03ad\\u03bd\\u03bf\\u03c5 \\u03c3\\u03b5 \\u03ad\\u03bd\\u03b1\\u03bd \\u03b9\\u03c3\\u03c4\\u03cc\\u03c4\\u03bf\\u03c0\\u03bf, \\u03b3\\u03bd\\u03c9\\u03c3\\u03c4\\u03cc \\u03c9\\u03c2 Cross-Site Request Forgery. \\u0394\\u03b5\\u03bd \\u03c0\\u03b5\\u03c1\\u03b9\\u03ad\\u03c7\\u03b5\\u03b9 \\u03c0\\u03bb\\u03b7\\u03c1\\u03bf\\u03c6\\u03bf\\u03c1\\u03af\\u03b5\\u03c2 \\u03c3\\u03c7\\u03b5\\u03c4\\u03b9\\u03ba\\u03ac \\u03bc\\u03b5 \\u03c4\\u03bf \\u03c7\\u03c1\\u03ae\\u03c3\\u03c4\\u03b7 \\u03ba\\u03b1\\u03b9 \\u03ba\\u03b1\\u03c4\\u03b1\\u03c3\\u03c4\\u03c1\\u03ad\\u03c6\\u03b5\\u03c4\\u03b1\\u03b9 \\u03ba\\u03b1\\u03c4\\u03ac \\u03c4\\u03bf \\u03ba\\u03bb\\u03b5\\u03af\\u03c3\\u03b9\\u03bc\\u03bf \\u03c4\\u03bf\\u03c5 \\u03c0\\u03c1\\u03bf\\u03b3\\u03c1\\u03ac\\u03bc\\u03bc\\u03b1\\u03c4\\u03bf\\u03c2 \\u03c0\\u03b5\\u03c1\\u03b9\\u03ae\\u03b3\\u03b7\\u03c3\\u03b7\\u03c2.&quot;}">\n                          \u0391\u03c5\u03c4\u03cc \u03b5\u03af\u03bd\u03b1\u03b9 \u03ad\u03bd\u03b1 cookie \u03ba\u03b1\u03c4\u03ac \u03c4\u03b7\u03c2 \u03c0\u03bb\u03b1\u03c3\u03c4\u03bf\u03b3\u03c1\u03ac\u03c6\u03b7\u03c3\u03b7\u03c2 \u03c0\u03bf\u03c5 